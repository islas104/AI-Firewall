{
  "name": "ai-agent-budget-proxy",
  "version": "2.2.0",
  "description": "Budget-enforcing proxy between AI agents and the OpenAI API — atomic Redis spend tracking, per-agent limits, streaming metering, kill-switch, and a live dashboard.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "demo": "MOCK_UPSTREAM=true node server.js",
    "test": "node --test \"test/*.test.js\"",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\" \"server.js\" \"public/**/*.js\""
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "openai",
    "proxy",
    "budget",
    "rate-limit",
    "redis",
    "ai-agent",
    "cost-control",
    "kill-switch"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "openai": "^6.45.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4"
  }
}
