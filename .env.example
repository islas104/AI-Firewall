# ---- Upstream ----
# Your real OpenAI API key. Required unless MOCK_UPSTREAM=true.
OPENAI_API_KEY=sk-your-real-openai-key

# Run the entire product without OpenAI: deterministic mock completions,
# real budgets, real streaming, real kill-switch. Great for demos and CI.
MOCK_UPSTREAM=false

# Point the upstream elsewhere (Azure OpenAI, a gateway, or a local mock).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Upstream resilience
# UPSTREAM_TIMEOUT_MS=60000
# UPSTREAM_MAX_RETRIES=1

# ---- Budget ----
# Global hard daily ceiling per agent, in USD (UTC calendar day).
# Per-agent overrides via PUT /admin/agents/:id/limit.
HARD_DAILY_LIMIT_USD=10.00

# Fleet-wide daily ceiling across ALL agents combined. Closes the agent-ID
# rotation loophole (fresh IDs cannot mint fresh budgets past this).
# Defaults to 2x HARD_DAILY_LIMIT_USD. 0 disables.
# TOTAL_DAILY_LIMIT_USD=20.00

# Optional closed set of permitted agent IDs. Unknown agents get 403.
# AGENT_ALLOWLIST=crawler-01,scraper-02,summarizer-03

# Requests/minute per agent (velocity brake, separate from the dollar
# ceiling). 0 disables.
RATE_LIMIT_RPM=60

# Requests/minute per client IP, applied before auth (throttles credential
# stuffing and 401 hammering). 0 disables.
IP_RATE_LIMIT_RPM=120

# Failed auth attempts allowed per IP per minute before a 429 lockout.
AUTH_FAIL_LIMIT_PER_MIN=10

# Completion-token estimate used for budget reservation when a request has
# no max_tokens. Pessimistic on purpose.
# DEFAULT_COMPLETION_ESTIMATE=1024

# ---- Auth (REQUIRED for production) ----
# Clients must send "Authorization: Bearer <key>" on /v1/* when set.
PROXY_API_KEY=

# Admin, dashboard, and /metrics require "X-Admin-Key: <key>" when set.
ADMIN_API_KEY=

# ---- Ops ----
LOG_LEVEL=info
# Set to the number of trusted reverse-proxy hops (e.g. 1 behind one LB)
# so client IPs come from X-Forwarded-For.
TRUST_PROXY=0
# Only enable when TLS terminates in front of the proxy.
ENABLE_HSTS=false

# ---- Infrastructure ----
REDIS_URL=redis://127.0.0.1:6379
PORT=3000

# ---- Pricing ----
# Override or extend pricing (USD per 1,000 tokens) without editing code.
# Any model not listed falls back to the built-in DEFAULT tier.
# MODEL_PRICING={"gpt-4o-mini":{"input":0.0015,"output":0.002},"gpt-4o":{"input":0.005,"output":0.015}}
