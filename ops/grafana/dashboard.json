{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "AI Firewall — Budget & Ops",
  "uid": "ai-firewall",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Total metered spend (USD)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "targets": [{ "expr": "agent_spend_usd_total", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Budget halts (kill-switch)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "increase(budget_halts_total[1h])", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Upstream errors (1h)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(upstream_errors_total[1h])", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Auth failures (1h)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(auth_failures_total[1h])", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Spend rate (USD/min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [{ "expr": "rate(agent_spend_usd_total[5m]) * 60", "refId": "A", "legendFormat": "USD/min" }]
    },
    {
      "type": "timeseries",
      "title": "Request rate by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum by (status) (rate(http_requests_total[5m]))", "refId": "A", "legendFormat": "{{status}}" }]
    },
    {
      "type": "timeseries",
      "title": "Request latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "C", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Enforcement events (halts / contention / rate-limits)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(budget_halts_total[5m])", "refId": "A", "legendFormat": "halts" },
        { "expr": "rate(global_budget_halts_total[5m])", "refId": "B", "legendFormat": "global halts" },
        { "expr": "rate(budget_contention_total[5m])", "refId": "C", "legendFormat": "contention" },
        { "expr": "rate(rate_limited_total[5m])", "refId": "D", "legendFormat": "rate-limited" }
      ]
    }
  ]
}
